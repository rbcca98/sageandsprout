---
import Base from '../layouts/Base.astro';
---

<Base
  title="Contact | Sage & Sprout"
  description="Get in touch with Sage & Sprout — questions, corrections, or tool suggestions welcome."
  breadcrumbs={[{ label: 'Contact', href: '/contact/' }]}
>
  <div style="max-width:560px;margin:0 auto;padding:3rem 1.25rem 5rem;">
    <h1 style="font-family:var(--font-family-display);font-size:clamp(1.8rem,4vw,2.4rem);font-weight:700;color:var(--color-ink);margin:0 0 .5rem;">Contact</h1>
    <p style="color:var(--color-muted);margin:0 0 2.5rem;">Questions, corrections, or suggestions for new tools? We'd love to hear from you.</p>

    <form
      name="contact"
      method="POST"
      data-netlify="true"
      style="display:flex;flex-direction:column;gap:1.25rem;"
    >
      <div>
        <label for="name" style="display:block;font-size:.85rem;font-weight:600;margin-bottom:.4rem;color:var(--color-ink);">Your name</label>
        <input
          type="text" id="name" name="name" required autocomplete="name"
          style="width:100%;padding:.65rem .9rem;border-radius:var(--radius-sm);border:1.5px solid var(--color-line);background:var(--color-surface-2);font-size:1rem;color:var(--color-ink);font-family:var(--font-family-body);"
        />
      </div>
      <div>
        <label for="email" style="display:block;font-size:.85rem;font-weight:600;margin-bottom:.4rem;color:var(--color-ink);">Email address</label>
        <input
          type="email" id="email" name="email" required autocomplete="email"
          style="width:100%;padding:.65rem .9rem;border-radius:var(--radius-sm);border:1.5px solid var(--color-line);background:var(--color-surface-2);font-size:1rem;color:var(--color-ink);font-family:var(--font-family-body);"
        />
      </div>
      <div>
        <label for="message" style="display:block;font-size:.85rem;font-weight:600;margin-bottom:.4rem;color:var(--color-ink);">Message</label>
        <textarea
          id="message" name="message" required rows="5"
          style="width:100%;padding:.65rem .9rem;border-radius:var(--radius-sm);border:1.5px solid var(--color-line);background:var(--color-surface-2);font-size:1rem;color:var(--color-ink);font-family:var(--font-family-body);resize:vertical;"
        ></textarea>
      </div>
      <button
        type="submit"
        style="padding:.75rem 1.75rem;border-radius:999px;border:none;background:var(--color-primary);color:#fff;font-size:.95rem;font-weight:600;cursor:pointer;transition:background .15s;align-self:flex-start;"
      >
        Send message
      </button>
    </form>

    <p style="margin-top:2rem;font-size:.82rem;color:var(--color-muted);">
      We read every message. For urgent medical questions, please contact your healthcare provider directly — we are not able to provide personalized medical advice.
    </p>
  </div>
</Base>
