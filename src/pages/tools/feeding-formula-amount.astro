---
import ToolPage from '../../layouts/ToolPage.astro';
import copy from '../../data/tools/feeding-formula-amount';
import { toolSchema } from '../../data/tools/_schema';
---

<ToolPage
  title={copy.title}
  headline={copy.headline}
  hook={copy.hook}
  description={copy.description}
  breadcrumbs={[{ label: copy.breadcrumb, href: copy.path }]}
  faqs={copy.faqs}
  relatedTools={copy.related}
  sources={copy.sources}
  schema={toolSchema(copy)}
  reviewedDate={copy.reviewedDate}
>
  <div slot="tool">
    <!-- Feeding type tabs -->
    <div style="display:flex;gap:0.5rem;margin-bottom:1.25rem;">
      {(['formula','breast','mixed'] as const).map((t, i) => (
        <button data-type={t}
          class={`feed-type-btn${i === 0 ? ' active' : ''}`}
          style={`flex:1;padding:0.6rem 0.5rem;border-radius:var(--radius-sm);border:1.5px solid ${i===0 ? 'var(--color-primary)' : 'var(--color-line)'};background:${i===0 ? 'var(--color-primary)' : 'transparent'};color:${i===0 ? '#fff' : 'var(--color-muted)'};font-weight:600;cursor:pointer;font-size:0.85rem;`}>
          {t === 'formula' ? 'Formula' : t === 'breast' ? 'Breastfeeding' : 'Mixed'}
        </button>
      ))}
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.5rem;">
      <div>
        <label style="display:block;font-size:0.82rem;font-weight:600;color:var(--color-muted);margin-bottom:0.4rem;" for="feed-age">Baby's age (months)</label>
        <input id="feed-age" type="number" min="0" max="12" value="2" />
      </div>
      <div>
        <label style="display:block;font-size:0.82rem;font-weight:600;color:var(--color-muted);margin-bottom:0.4rem;" for="feed-weight">Baby's weight (lb)</label>
        <input id="feed-weight" type="number" min="4" max="40" step="0.5" value="12" />
      </div>
    </div>


    <!-- Result panel -->
    <div id="feed-result" style="min-height:220px;margin-top:1.5rem;display:none;">
      <p id="feed-age-group" style="margin:0 0 1rem;font-size:0.82rem;font-weight:700;color:var(--color-primary);text-transform:uppercase;letter-spacing:.06em;"></p>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">
        <div style="padding:1rem;background:transparent;border:1px solid var(--color-line);border-radius:3px;text-align:center;">
          <p style="margin:0;font-size:0.75rem;color:var(--color-muted);font-weight:600;">PER FEEDING</p>
          <p id="feed-per-feed" style="margin:0.2rem 0 0;font-size:1.5rem;font-family:var(--font-family-display);font-weight:700;color:var(--color-accent);"></p>
          <p id="feed-per-feed-ml" style="margin:0;font-size:0.8rem;color:var(--color-muted);"></p>
        </div>
        <div style="padding:1rem;background:transparent;border:1px solid var(--color-line);border-radius:3px;text-align:center;">
          <p style="margin:0;font-size:0.75rem;color:var(--color-muted);font-weight:600;">FEEDS PER DAY</p>
          <p id="feed-per-day" style="margin:0.2rem 0 0;font-size:1.5rem;font-family:var(--font-family-display);font-weight:700;color:var(--color-primary);"></p>
        </div>
      </div>

      <div style="padding:1rem;background:var(--color-primary);border-radius:var(--radius-sm);text-align:center;margin-bottom:1rem;">
        <p style="margin:0;font-size:0.78rem;color:rgba(255,255,255,.8);font-weight:600;">TOTAL DAILY AMOUNT</p>
        <p id="feed-daily" style="margin:0.2rem 0 0;font-size:1.5rem;font-family:var(--font-family-display);font-weight:700;color:#fff;"></p>
      </div>

      <p id="feed-notes" style="margin:0;font-size:0.85rem;color:var(--color-muted);line-height:1.65;"></p>
      <p id="feed-solids" style="margin:0.75rem 0 0;padding:0.75rem 1rem;background:var(--color-accent-light);border-radius:var(--radius-sm);font-size:0.85rem;color:var(--color-accent-dark);display:none;"></p>
    </div>
  </div>

  <Fragment slot="content" set:html={copy.contentHtml} />
</ToolPage>

<script>
  import { calculateFeeding } from '../../islands/feeding.js';
  import type { FeedingType } from '../../islands/feeding.js';

  let currentType: FeedingType = 'formula';

  document.querySelectorAll('.feed-type-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      currentType = (btn as HTMLElement).dataset.type as FeedingType;
      document.querySelectorAll('.feed-type-btn').forEach(b => {
        const isActive = (b as HTMLElement).dataset.type === currentType;
        (b as HTMLElement).style.background = isActive ? 'var(--color-primary)' : 'transparent';
        (b as HTMLElement).style.color = isActive ? '#fff' : 'var(--color-muted)';
        (b as HTMLElement).style.borderColor = isActive ? 'var(--color-primary)' : 'var(--color-line)';
      });
      calc();
    });
  });

  function calc() {
    const age    = parseFloat((document.getElementById('feed-age') as HTMLInputElement).value) || 0;
    const weight = parseFloat((document.getElementById('feed-weight') as HTMLInputElement).value) || 0;

    const result = calculateFeeding({ ageMonths: age, weightLbs: weight, feedingType: currentType });
    if (!result) return;

    const panel = document.getElementById('feed-result')!;
    panel.style.display = 'block';

    document.getElementById('feed-age-group')!.textContent = result.ageGroup;
    document.getElementById('feed-per-feed')!.textContent = `${result.ozPerFeedLow}–${result.ozPerFeedHigh} oz`;
    document.getElementById('feed-per-feed-ml')!.textContent = `(${result.mlPerFeedLow}–${result.mlPerFeedHigh} mL)`;
    document.getElementById('feed-per-day')!.textContent = `${result.feedsPerDayLow}–${result.feedsPerDayHigh}x`;

    const daily = `${result.dailyOzLow}–${result.dailyOzHigh} oz / day`;
    const dailyMl = `(${result.dailyMlLow}–${result.dailyMlHigh} mL)`;
    document.getElementById('feed-daily')!.textContent = `${daily}  ${dailyMl}`;

    document.getElementById('feed-notes')!.textContent = result.notes;

    const solidsEl = document.getElementById('feed-solids')!;
    if (result.solidsNote) {
      solidsEl.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-2px;margin-right:4px"><ellipse cx="12" cy="7" rx="2.6" ry="3.6"/><path d="M12 10.6V20.5"/></svg>' + result.solidsNote;
      solidsEl.style.display = 'block';
    } else {
      solidsEl.style.display = 'none';
    }

    // Persist URL state
    const url = new URL(window.location.href);
    url.searchParams.set('age', age.toString());
    url.searchParams.set('wt', weight.toString());
    url.searchParams.set('type', currentType);
    history.replaceState(null, '', url);
  }

  // Restore from URL
  const p = new URLSearchParams(window.location.search);
  if (p.get('age')) (document.getElementById('feed-age') as HTMLInputElement).value = p.get('age')!;
  if (p.get('wt'))  (document.getElementById('feed-weight') as HTMLInputElement).value = p.get('wt')!;
  const urlType = p.get('type');
  if (urlType && urlType !== currentType) {
    (document.querySelector(`.feed-type-btn[data-type="${urlType}"]`) as HTMLElement | null)?.click();
  }

  // Live-update
  let _t: ReturnType<typeof setTimeout>;
  ['feed-age', 'feed-weight'].forEach(id =>
    document.getElementById(id)!.addEventListener('input', () => { clearTimeout(_t); _t = setTimeout(calc, 150); })
  );

  calc();
</script>
