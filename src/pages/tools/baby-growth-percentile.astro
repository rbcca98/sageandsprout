---
import ToolPage from '../../layouts/ToolPage.astro';
import copy from '../../data/tools/baby-growth-percentile';
import { toolSchema } from '../../data/tools/_schema';
---

<ToolPage
  title={copy.title}
  headline={copy.headline}
  hook={copy.hook}
  description={copy.description}
  breadcrumbs={[{ label: copy.breadcrumb, href: copy.path }]}
  faqs={copy.faqs}
  relatedTools={copy.related}
  sources={copy.sources}
  schema={toolSchema(copy)}
  reviewedDate={copy.reviewedDate}
>
  <div slot="tool">
    <!-- Unit toggle -->
    <div style="display:flex;gap:0.5rem;margin-bottom:1.25rem;">
      <button id="gp-unit-us" data-unit="us"
        style="flex:1;padding:0.6rem;border-radius:var(--radius-sm);border:1.5px solid var(--color-primary);background:var(--color-primary);color:#fff;font-weight:600;cursor:pointer;font-size:0.9rem;">
        US (lb / in)
      </button>
      <button id="gp-unit-metric" data-unit="metric"
        style="flex:1;padding:0.6rem;border-radius:var(--radius-sm);border:1.5px solid var(--color-line);background:transparent;color:var(--color-muted);font-weight:600;cursor:pointer;font-size:0.9rem;">
        Metric (kg / cm)
      </button>
    </div>

    <!-- Measure tabs -->
    <div style="display:flex;gap:0.5rem;margin-bottom:1.25rem;">
      {(['weight','length','headcirc'] as const).map((m, i) => (
        <button data-measure={m}
          class={`gp-measure-btn${i === 0 ? ' active' : ''}`}
          style={`flex:1;padding:0.55rem 0.5rem;border-radius:var(--radius-sm);border:1.5px solid ${i===0 ? 'var(--color-primary)' : 'var(--color-line)'};background:${i===0 ? 'var(--color-primary)' : 'transparent'};color:${i===0 ? '#fff' : 'var(--color-muted)'};font-weight:600;cursor:pointer;font-size:0.8rem;`}>
          {m === 'weight' ? 'Weight' : m === 'length' ? 'Length' : 'Head circ.'}
        </button>
      ))}
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem;margin-bottom:1.5rem;">
      <div>
        <label style="display:block;font-size:0.82rem;font-weight:600;color:var(--color-muted);margin-bottom:0.4rem;" for="gp-age">Age (months)</label>
        <input id="gp-age" type="number" min="0" max="24" value="6"
          style="width:100%;padding:0.7rem 0.9rem;border:1.5px solid var(--color-line);border-radius:var(--radius-sm);font-size:1rem;color:var(--color-ink);background:var(--color-bg);box-sizing:border-box;" />
      </div>
      <div>
        <label style="display:block;font-size:0.82rem;font-weight:600;color:var(--color-muted);margin-bottom:0.4rem;">Sex</label>
        <div style="display:flex;gap:0.75rem;padding-top:0.5rem;">
          <label style="display:flex;align-items:center;gap:0.35rem;cursor:pointer;font-size:0.95rem;">
            <input type="radio" name="gp-sex" value="M" checked /> Boy
          </label>
          <label style="display:flex;align-items:center;gap:0.35rem;cursor:pointer;font-size:0.95rem;">
            <input type="radio" name="gp-sex" value="F" /> Girl
          </label>
        </div>
      </div>
      <div>
        <label id="gp-value-label" style="display:block;font-size:0.82rem;font-weight:600;color:var(--color-muted);margin-bottom:0.4rem;" for="gp-value">Weight (lb)</label>
        <input id="gp-value" type="number" min="0" step="0.1" value="16"
          style="width:100%;padding:0.7rem 0.9rem;border:1.5px solid var(--color-line);border-radius:var(--radius-sm);font-size:1rem;color:var(--color-ink);background:var(--color-bg);box-sizing:border-box;" />
      </div>
    </div>

    <button id="gp-calculate"
      class="btn btn--primary btn--block">
      Calculate percentile
    </button>

    <!-- Result panel -->
    <div id="gp-result" style="min-height:200px;margin-top:1.5rem;display:none;">
      <div style="text-align:center;padding:1.5rem;background:transparent;border:1px solid var(--color-line);border-radius:3px;">
        <p style="margin:0;font-size:0.82rem;font-weight:600;color:var(--color-muted);" id="gp-measure-label">WEIGHT PERCENTILE</p>
        <p id="gp-percentile" style="margin:0.25rem 0;font-size:3.5rem;font-family:var(--font-family-display);font-weight:700;color:var(--color-accent);"></p>
        <p id="gp-zscore" style="margin:0;font-size:0.85rem;color:var(--color-muted);"></p>
      </div>
      <p id="gp-interp" style="margin:1rem 0 0;padding:0.85rem 1rem;border-radius:var(--radius-sm);font-size:0.9rem;font-weight:500;"></p>
      <p id="gp-median" style="margin:0.5rem 0 0;font-size:0.82rem;color:var(--color-muted);text-align:center;"></p>
    </div>
  </div>

  <Fragment slot="content" set:html={copy.contentHtml} />
</ToolPage>

<script>
  import { calculateGrowthPercentile, lbsToKg, inchesToCm } from '../../islands/growth-percentile.js';
  import type { Measure, Sex } from '../../islands/growth-percentile.js';

  let currentUnit: 'us' | 'metric' = 'us';
  let currentMeasure: Measure = 'weight';

  const LABELS: Record<Measure, { us: string; metric: string }> = {
    weight:   { us: 'Weight (lb)', metric: 'Weight (kg)' },
    length:   { us: 'Length (in)', metric: 'Length (cm)' },
    headcirc: { us: 'Head circ. (in)', metric: 'Head circ. (cm)' },
  };

  function updateValueLabel() {
    document.getElementById('gp-value-label')!.textContent = LABELS[currentMeasure][currentUnit];
  }

  // Unit buttons
  document.querySelectorAll('[data-unit]').forEach(btn => {
    btn.addEventListener('click', () => {
      currentUnit = (btn as HTMLElement).dataset.unit as 'us' | 'metric';
      document.querySelectorAll('[data-unit]').forEach(b => {
        const isActive = (b as HTMLElement).dataset.unit === currentUnit;
        (b as HTMLElement).style.background = isActive ? 'var(--color-primary)' : 'transparent';
        (b as HTMLElement).style.color = isActive ? '#fff' : 'var(--color-muted)';
        (b as HTMLElement).style.borderColor = isActive ? 'var(--color-primary)' : 'var(--color-line)';
      });
      updateValueLabel();
    });
  });

  // Measure buttons
  document.querySelectorAll('.gp-measure-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      currentMeasure = (btn as HTMLElement).dataset.measure as Measure;
      document.querySelectorAll('.gp-measure-btn').forEach(b => {
        const isActive = (b as HTMLElement).dataset.measure === currentMeasure;
        (b as HTMLElement).style.background = isActive ? 'var(--color-primary)' : 'transparent';
        (b as HTMLElement).style.color = isActive ? '#fff' : 'var(--color-muted)';
        (b as HTMLElement).style.borderColor = isActive ? 'var(--color-primary)' : 'var(--color-line)';
      });
      updateValueLabel();
    });
  });

  document.getElementById('gp-calculate')!.addEventListener('click', () => {
    const age   = parseFloat((document.getElementById('gp-age') as HTMLInputElement).value) || 0;
    const sex   = (document.querySelector('input[name="gp-sex"]:checked') as HTMLInputElement)?.value as Sex;
    let value   = parseFloat((document.getElementById('gp-value') as HTMLInputElement).value) || 0;

    // Convert to metric if US units
    if (currentUnit === 'us') {
      value = currentMeasure === 'weight' ? lbsToKg(value) : inchesToCm(value);
    }

    const result = calculateGrowthPercentile({ ageMonths: Math.round(age), sex, measure: currentMeasure, value });
    if (!result) return;

    const panel = document.getElementById('gp-result')!;
    panel.style.display = 'block';

    document.getElementById('gp-measure-label')!.textContent = result.measureLabel.toUpperCase() + ' PERCENTILE';
    document.getElementById('gp-percentile')!.textContent = result.percentile + 'th';
    document.getElementById('gp-zscore')!.textContent = `Z-score: ${result.zScore}`;
    document.getElementById('gp-median')!.textContent = `WHO median for this age/sex: ${result.medianForAge} ${result.unit}`;

    const interpEl = document.getElementById('gp-interp')!;
    interpEl.textContent = result.interpretation;
    interpEl.style.background = result.interpretationClass === 'normal' ? '#DCE4D3' : '#F1DACB';
    interpEl.style.color = result.interpretationClass === 'normal' ? '#2C4234' : '#8A3D22';
  });
</script>
