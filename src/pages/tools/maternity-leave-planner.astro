---
import ToolPage from '../../layouts/ToolPage.astro';
import { US_STATES } from '../../islands/maternity-leave.js';
import copy from '../../data/tools/maternity-leave-planner';
import { toolSchema } from '../../data/tools/_schema';
---

<ToolPage
  title={copy.title}
  headline={copy.headline}
  hook={copy.hook}
  description={copy.description}
  breadcrumbs={[{ label: copy.breadcrumb, href: copy.path }]}
  faqs={copy.faqs}
  relatedTools={copy.related}
  sources={copy.sources}
  schema={toolSchema(copy)}
  reviewedDate={copy.reviewedDate}
>
  <div slot="tool">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;margin-bottom:1.25rem;">
      <div>
        <label style="display:block;font-size:0.82rem;font-weight:600;color:var(--color-muted);margin-bottom:0.4rem;" for="ml-due">Estimated due date</label>
        <input id="ml-due" type="date"
          style="width:100%;padding:0.7rem 0.9rem;border:1.5px solid var(--color-line);border-radius:var(--radius-sm);font-size:1rem;color:var(--color-ink);background:var(--color-bg);box-sizing:border-box;" />
      </div>
      <div>
        <label style="display:block;font-size:0.82rem;font-weight:600;color:var(--color-muted);margin-bottom:0.4rem;" for="ml-lastday">Last work day (planned)</label>
        <input id="ml-lastday" type="date"
          style="width:100%;padding:0.7rem 0.9rem;border:1.5px solid var(--color-line);border-radius:var(--radius-sm);font-size:1rem;color:var(--color-ink);background:var(--color-bg);box-sizing:border-box;" />
      </div>
    </div>

    <div class="tool-grid-3" style="margin-bottom:1.25rem;">
      <div>
        <label style="display:block;font-size:0.82rem;font-weight:600;color:var(--color-muted);margin-bottom:0.4rem;" for="ml-employer-paid">Employer paid weeks</label>
        <input id="ml-employer-paid" type="number" min="0" max="52" value="0"
          style="width:100%;padding:0.7rem 0.9rem;border:1.5px solid var(--color-line);border-radius:var(--radius-sm);font-size:1rem;color:var(--color-ink);background:var(--color-bg);box-sizing:border-box;" />
      </div>
      <div>
        <label style="display:block;font-size:0.82rem;font-weight:600;color:var(--color-muted);margin-bottom:0.4rem;" for="ml-pto">PTO/sick weeks</label>
        <input id="ml-pto" type="number" min="0" max="12" value="0"
          style="width:100%;padding:0.7rem 0.9rem;border:1.5px solid var(--color-line);border-radius:var(--radius-sm);font-size:1rem;color:var(--color-ink);background:var(--color-bg);box-sizing:border-box;" />
      </div>
      <div>
        <label style="display:block;font-size:0.82rem;font-weight:600;color:var(--color-muted);margin-bottom:0.4rem;" for="ml-state">State</label>
        <select id="ml-state"
          style="width:100%;padding:0.7rem 0.9rem;border:1.5px solid var(--color-line);border-radius:var(--radius-sm);font-size:0.9rem;color:var(--color-ink);background:var(--color-bg);box-sizing:border-box;">
          {US_STATES.map(([code, name]) => <option value={code}>{name}</option>)}
        </select>
      </div>
    </div>

    <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.5rem;padding:0.75rem 1rem;background:transparent;border:1px solid var(--color-line);border-radius:3px;">
      <input type="checkbox" id="ml-fmla" checked style="width:18px;height:18px;cursor:pointer;" />
      <label for="ml-fmla" style="cursor:pointer;font-size:0.9rem;color:var(--color-ink);">I am eligible for FMLA (12+ months employed, employer ≥ 50 employees)</label>
    </div>

    <button id="ml-calculate"
      class="btn btn--primary btn--block">
      Plan my leave
    </button>

    <!-- Result panel -->
    <div id="ml-result" style="min-height:300px;margin-top:1.5rem;display:none;">

      <!-- Paid / Unpaid summary -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.25rem;">
        <div style="padding:1rem;background:#DCE4D3;border-radius:var(--radius-sm);text-align:center;">
          <p style="margin:0;font-size:0.75rem;color:#2C4234;font-weight:700;">PAID WEEKS</p>
          <p id="ml-paid-weeks" style="margin:0.15rem 0 0;font-size:2rem;font-family:var(--font-family-display);font-weight:700;color:#2C4234;"></p>
        </div>
        <div style="padding:1rem;background:#F1DACB;border-radius:var(--radius-sm);text-align:center;">
          <p style="margin:0;font-size:0.75rem;color:#8A3D22;font-weight:700;">UNPAID (PROTECTED) WEEKS</p>
          <p id="ml-unpaid-weeks" style="margin:0.15rem 0 0;font-size:2rem;font-family:var(--font-family-display);font-weight:700;color:#8A3D22;"></p>
        </div>
      </div>

      <!-- Timeline -->
      <div id="ml-timeline" style="display:flex;flex-direction:column;gap:0.6rem;margin-bottom:1.25rem;"></div>

      <!-- State PFL info -->
      <div id="ml-pfl-box" style="display:none;padding:0.9rem 1rem;background:transparent;border:1px solid var(--color-line);border-radius:3px;border-left:3px solid var(--color-primary);margin-bottom:1rem;">
        <p id="ml-pfl-text" style="margin:0;font-size:0.85rem;color:var(--color-ink);"></p>
      </div>

      <!-- Notes -->
      <div id="ml-notes-list" style="display:flex;flex-direction:column;gap:0.5rem;"></div>

      <p style="margin:1rem 0 0;font-size:0.78rem;color:var(--color-muted);">
        This planner provides a general estimate. Leave policies vary by employer and state. Always confirm your specific entitlements with HR and your state labor office.
      </p>
    </div>
  </div>

  <Fragment slot="content" set:html={copy.contentHtml} />
</ToolPage>

<script>
  import { calculateMaternityLeave, formatDateShort } from '../../islands/maternity-leave.js';

  function setDateDefaults() {
    const today = new Date();
    const due   = new Date(today);
    due.setMonth(due.getMonth() + 7);
    const last  = new Date(today);
    last.setMonth(last.getMonth() + 6);
    (document.getElementById('ml-due') as HTMLInputElement).value    = due.toISOString().split('T')[0];
    (document.getElementById('ml-lastday') as HTMLInputElement).value = last.toISOString().split('T')[0];
  }
  setDateDefaults();

  document.getElementById('ml-calculate')!.addEventListener('click', () => {
    const dueDate        = (document.getElementById('ml-due') as HTMLInputElement).value;
    const lastWorkDay    = (document.getElementById('ml-lastday') as HTMLInputElement).value;
    const employerPaid   = parseInt((document.getElementById('ml-employer-paid') as HTMLInputElement).value) || 0;
    const ptoPaid        = parseInt((document.getElementById('ml-pto') as HTMLInputElement).value) || 0;
    const statePFL       = (document.getElementById('ml-state') as HTMLSelectElement).value;
    const fmlaEligible   = (document.getElementById('ml-fmla') as HTMLInputElement).checked;

    const result = calculateMaternityLeave({ dueDate, lastWorkDay, fmlaEligible, employerPaidWeeks: employerPaid, statePFL, ptoPaidWeeks: ptoPaid });
    if (!result) return;

    const panel = document.getElementById('ml-result')!;
    panel.style.display = 'block';

    document.getElementById('ml-paid-weeks')!.textContent   = result.totalPaidWeeks.toString();
    document.getElementById('ml-unpaid-weeks')!.textContent = result.totalUnpaidWeeks.toString();

    // Timeline
    const tl = document.getElementById('ml-timeline')!;
    tl.innerHTML = '';
    const typeStyles: Record<string, string> = {
      start:     'background:#DCE4D3;color:#2C4234;',
      milestone: 'background:rgba(244,236,220,.1);color:var(--color-ink);',
      end:       'background:var(--color-primary);color:#fff;',
    };
    result.timeline.forEach(item => {
      const el = document.createElement('div');
      el.style.cssText = `padding:0.75rem 1rem;border-radius:var(--radius-sm);display:flex;justify-content:space-between;align-items:center;${typeStyles[item.type]}`;
      el.innerHTML = `<span style="font-size:0.9rem;font-weight:600;">${item.label}</span><span style="font-size:0.9rem;font-weight:700;">${formatDateShort(item.date)}</span>`;
      tl.appendChild(el);
    });

    // State PFL
    const pflBox  = document.getElementById('ml-pfl-box')!;
    const pflText = document.getElementById('ml-pfl-text')!;
    if (result.statePFLInfo) {
      pflBox.style.display = 'block';
      pflText.textContent = `${result.statePFLInfo.name}: up to ${result.statePFLInfo.weeks} weeks at ~${result.statePFLInfo.payPercent}% wage replacement. ${result.statePFLInfo.waitingDays > 0 ? `Waiting period: ${result.statePFLInfo.waitingDays} days.` : 'No waiting period.'} File your claim early, since many states require filing within the first week of leave.`;
    } else {
      pflBox.style.display = 'none';
    }

    // Notes
    const nl = document.getElementById('ml-notes-list')!;
    nl.innerHTML = '';
    result.notes.forEach(note => {
      const p = document.createElement('p');
      p.style.cssText = 'margin:0;font-size:0.84rem;color:var(--color-muted);line-height:1.6;padding:0.5rem 0;border-top:1px solid var(--color-line);';
      p.textContent = note;
      nl.appendChild(p);
    });
  });
</script>
