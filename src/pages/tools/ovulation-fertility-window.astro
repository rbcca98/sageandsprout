---
import ToolPage from '../../layouts/ToolPage.astro';
import copy from '../../data/tools/ovulation-fertility-window';
import { toolSchema } from '../../data/tools/_schema';
---

<ToolPage
  title={copy.title}
  headline={copy.headline}
  hook={copy.hook}
  description={copy.description}
  breadcrumbs={[{ label: copy.breadcrumb, href: copy.path }]}
  faqs={copy.faqs}
  relatedTools={copy.related}
  sources={copy.sources}
  schema={toolSchema(copy)}
  reviewedDate={copy.reviewedDate}
>

  <!-- ── TOOL SLOT ────────────────────────────────── -->
  <div slot="tool" id="ovul-calc">
    <div style="display:flex;gap:1rem;flex-wrap:wrap;align-items:flex-end;margin-bottom:1.5rem;">
      <!-- LMP input -->
      <div style="flex:1;min-width:200px;">
        <label for="o-lmp" style="display:block;font-size:.85rem;font-weight:600;margin-bottom:.4rem;color:var(--color-ink);">
          First day of last period
        </label>
        <input
          type="date"
          id="o-lmp"
          autocomplete="off"
          style="
            width:100%;padding:.65rem .9rem;border-radius:var(--radius-sm);
            border:1.5px solid var(--color-line);background:var(--color-surface-2);
            font-size:1rem;color:var(--color-ink);font-family:var(--font-family-body);
          "
        />
      </div>
      <!-- Cycle length -->
      <div style="min-width:150px;">
        <label for="o-cycle" style="display:block;font-size:.85rem;font-weight:600;margin-bottom:.4rem;color:var(--color-ink);">
          Average cycle length
        </label>
        <div style="display:flex;align-items:center;gap:.5rem;">
          <button id="o-minus" aria-label="Decrease" style="width:44px;height:44px;border-radius:50%;border:1.5px solid var(--color-line);background:var(--color-surface-2);cursor:pointer;font-size:1.1rem;display:grid;place-items:center;">−</button>
          <input
            type="number"
            id="o-cycle"
            min="21" max="35" value="28"
            style="width:60px;text-align:center;padding:.5rem;border-radius:var(--radius-sm);border:1.5px solid var(--color-line);background:var(--color-surface-2);font-size:1rem;color:var(--color-ink);font-family:var(--font-family-mono);"
          />
          <button id="o-plus" aria-label="Increase" style="width:44px;height:44px;border-radius:50%;border:1.5px solid var(--color-line);background:var(--color-surface-2);cursor:pointer;font-size:1.1rem;display:grid;place-items:center;">+</button>
          <span style="font-size:.85rem;color:var(--color-muted);">days</span>
        </div>
      </div>
    </div>

    <!-- Result panel -->
    <div id="o-result" aria-live="polite" style="min-height:300px;border-radius:var(--radius-sm);border:1.5px solid var(--color-line);overflow:hidden;">
      <div id="o-empty" style="height:300px;display:grid;place-items:center;text-align:center;padding:2rem;">
        <div>
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:block;margin:0 auto .6rem;">
            <ellipse cx="12" cy="8.1" rx="1.8" ry="2.8"/>
            <ellipse cx="12" cy="8.1" rx="1.8" ry="2.8" transform="rotate(72 12 12)"/>
            <ellipse cx="12" cy="8.1" rx="1.8" ry="2.8" transform="rotate(144 12 12)"/>
            <ellipse cx="12" cy="8.1" rx="1.8" ry="2.8" transform="rotate(216 12 12)"/>
            <ellipse cx="12" cy="8.1" rx="1.8" ry="2.8" transform="rotate(288 12 12)"/>
            <circle cx="12" cy="12" r="1.7" fill="var(--color-accent)" stroke="none"/>
          </svg>
          <p style="color:var(--color-muted);font-size:.95rem;margin:0;">Enter your period date above to see your fertile window</p>
        </div>
      </div>

      <div id="o-content" style="display:none;padding:1.75rem;">
        <p id="o-example" hidden style="font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:var(--color-accent);border:1px solid currentColor;display:inline-block;padding:.25rem .6rem;margin:0 0 .85rem;">Example. Enter your date above</p>
        <!-- Phase badge -->
        <p id="o-phase" style="font-size:.8rem;font-weight:600;text-transform:uppercase;letter-spacing:.07em;color:var(--color-primary);margin:0 0 .75rem;"></p>

        <!-- Key dates grid -->
        <div id="o-dates" style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-bottom:1.5rem;"></div>

        <!-- Fertile window timeline bar -->
        <div style="margin-bottom:1.5rem;">
          <p style="font-size:.8rem;font-weight:600;color:var(--color-muted);margin:0 0 .5rem;text-transform:uppercase;letter-spacing:.06em;">This cycle</p>
          <div id="o-timeline" style="display:flex;align-items:center;gap:2px;height:28px;"></div>
          <div style="display:flex;justify-content:space-between;font-size:.72rem;color:var(--color-muted);margin-top:.3rem;">
            <span id="o-period-start-label"></span>
            <span>Ovulation</span>
            <span id="o-next-period-label"></span>
          </div>
        </div>

        <!-- Alert if in fertile window -->
        <div id="o-window-alert" style="display:none;padding:.85rem 1rem;background:var(--color-accent-light);border-radius:var(--radius-sm);border-left:3px solid var(--color-accent);margin-bottom:1rem;">
          <p style="margin:0;font-size:.9rem;font-weight:600;color:var(--color-accent);">You may be in your fertile window today.</p>
          <p style="margin:.25rem 0 0;font-size:.82rem;color:var(--color-ink);">This is a calculated estimate. Confirm with an OPK for more accuracy.</p>
        </div>

      </div>
    </div>
  </div>

  <Fragment slot="content" set:html={copy.contentHtml} />
</ToolPage>

<!-- ── Client-side calculator ─────────────────────────────────── -->
<script>
  import { calculateOvulation, formatDate, formatDateShort } from '../../islands/ovulation.ts';

  const lmpInput   = document.getElementById('o-lmp')   as HTMLInputElement;
  const cycleInput = document.getElementById('o-cycle') as HTMLInputElement;
  const oMinus = document.getElementById('o-minus') as HTMLButtonElement;
  const oPlus  = document.getElementById('o-plus')  as HTMLButtonElement;
  const oEmpty   = document.getElementById('o-empty')!;
  const oContent = document.getElementById('o-content')!;

  // Restore URL state
  const params = new URLSearchParams(location.search);
  if (params.get('lmp'))   { lmpInput.value = params.get('lmp')!; }
  if (params.get('cycle')) { cycleInput.value = params.get('cycle')!; }

  // No date yet? Show a worked example (period 10 days ago) so the payoff is visible immediately.
  let exampleMode = false;
  if (!lmpInput.value) {
    const ex = new Date();
    ex.setDate(ex.getDate() - 10);
    lmpInput.value = ex.toISOString().split('T')[0];
    exampleMode = true;
  }
  update();

  function userEdit() { exampleMode = false; update(); }
  lmpInput.addEventListener('input', userEdit);
  cycleInput.addEventListener('input', userEdit);
  oMinus.addEventListener('click', () => { cycleInput.value = String(Math.max(21, +cycleInput.value - 1)); userEdit(); });
  oPlus.addEventListener('click',  () => { cycleInput.value = String(Math.min(35, +cycleInput.value + 1)); userEdit(); });

  function update() {
    const lmp   = lmpInput.value;
    const cycle = Number(cycleInput.value);
    if (!lmp || cycle < 21 || cycle > 35) { showEmpty(); return; }

    const r = calculateOvulation({ lmp, cycleLength: cycle });
    if (!r) { showEmpty(); return; }

    (document.getElementById('o-example') as HTMLElement).hidden = !exampleMode;

    // URL state — but never for the example values
    if (!exampleMode) {
      const url = new URL(location.href);
      url.searchParams.set('lmp', lmp);
      url.searchParams.set('cycle', String(cycle));
      history.replaceState(null, '', url);
    }

    // Phase badge
    (document.getElementById('o-phase') as HTMLElement).textContent = r.phaseLabel +
      (r.daysUntilFertileWindow !== null
        ? `, fertile window in ${r.daysUntilFertileWindow} day${r.daysUntilFertileWindow !== 1 ? 's' : ''}`
        : r.daysUntilOvulation !== null
          ? `, ovulation in ${r.daysUntilOvulation} day${r.daysUntilOvulation !== 1 ? 's' : ''}`
          : '');

    // Key dates grid
    const dates = [
      { label: 'Fertile window opens', date: r.fertileStart, accent: true },
      { label: 'Estimated ovulation', date: r.ovulationDate, accent: true },
      { label: 'Fertile window closes', date: r.fertileEnd, accent: false },
      { label: 'Start OPK testing', date: r.testDate, accent: false },
      { label: 'Next expected period', date: r.nextPeriod, accent: false },
      { label: 'Earliest pregnancy test', date: r.pregnancyTestDate, accent: false },
    ];

    (document.getElementById('o-dates') as HTMLElement).innerHTML = dates.map(d => `
      <div style="padding:.7rem .9rem;border-radius:var(--radius-sm);background:var(--color-surface-2);border:1.5px solid ${d.accent ? 'var(--color-accent)' : 'var(--color-line)'};">
        <p style="margin:0;font-size:.75rem;color:var(--color-muted);">${d.label}</p>
        <p style="margin:.2rem 0 0;font-size:.9rem;font-weight:600;font-family:var(--font-family-mono);color:${d.accent ? 'var(--color-accent)' : 'var(--color-ink)'};">${formatDateShort(d.date)}</p>
      </div>
    `).join('');

    // Simple timeline bar
    const lmpMs = new Date(lmp).getTime();
    const cycleMs = cycle * 86_400_000;
    const timelineEl = document.getElementById('o-timeline')!;
    const segments = cycle;
    const ovulDay = cycle - 14; // day within cycle
    let html = '';
    for (let i = 0; i < segments; i++) {
      const dayMs = lmpMs + i * 86_400_000;
      const d = new Date(dayMs);
      const today = new Date(); today.setHours(0,0,0,0);
      const isToday = d.getTime() === today.getTime();
      const isFertile = d >= r.fertileStart && d <= r.fertileEnd;
      const isOvul = d.toDateString() === r.ovulationDate.toDateString();
      const isPeriod = i < 5;
      const bg = isOvul
        ? 'var(--color-accent)'
        : isFertile
          ? '#E7A98C'
          : isPeriod
            ? 'rgba(123,115,96,.45)'
            : 'var(--color-line)';
      html += `<div title="${formatDateShort(d)}" style="flex:1;height:100%;border-radius:2px;background:${bg};outline:${isToday ? '2px solid var(--color-ink)' : 'none'};outline-offset:1px;"></div>`;
    }
    timelineEl.innerHTML = html;
    (document.getElementById('o-period-start-label') as HTMLElement).textContent = formatDateShort(new Date(lmp));
    (document.getElementById('o-next-period-label') as HTMLElement).textContent = formatDateShort(r.nextPeriod);

    // Fertile window alert
    const alertEl = document.getElementById('o-window-alert')!;
    alertEl.style.display = r.isInFertileWindow ? 'block' : 'none';

    showResult();
  }

  function showEmpty() { oEmpty.style.display = 'grid'; oContent.style.display = 'none'; }
  function showResult() {
    oEmpty.style.display = 'none';
    oContent.style.display = 'block';
    oContent.classList.remove('result-animate');
    void oContent.offsetWidth;
    oContent.classList.add('result-animate');
  }
</script>
