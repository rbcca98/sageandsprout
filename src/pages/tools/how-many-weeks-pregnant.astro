---
import ToolPage from '../../layouts/ToolPage.astro';
import copy from '../../data/tools/how-many-weeks-pregnant';
import { toolSchema } from '../../data/tools/_schema';
---

<ToolPage
  title={copy.title}
  headline={copy.headline}
  hook={copy.hook}
  description={copy.description}
  breadcrumbs={[{ label: copy.breadcrumb, href: copy.path }]}
  faqs={copy.faqs}
  relatedTools={copy.related}
  sources={copy.sources}
  schema={toolSchema(copy)}
  reviewedDate={copy.reviewedDate}
>

  <!-- ── TOOL SLOT ────────────────────────────────── -->
  <div slot="tool" id="weeks-calc">

    <!-- Mode toggle -->
    <div style="display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:1.5rem;" role="tablist" aria-label="Input method">
      {(['lmp','edd'] as const).map((m, i) => (
        <button
          role="tab"
          data-wmode={m}
          aria-selected={i === 0 ? 'true' : 'false'}
          style={`
            padding:.45rem 1rem;border-radius:999px;border:1.5px solid;
            font-size:.82rem;font-weight:600;cursor:pointer;transition:background .15s,color .15s,border-color .15s;
            ${i === 0
              ? 'background:var(--color-primary);color:#fff;border-color:var(--color-primary);'
              : 'background:transparent;color:var(--color-muted);border-color:var(--color-line);'}
          `}
        >
          {m === 'lmp' ? 'I know my LMP' : 'I know my due date'}
        </button>
      ))}
    </div>

    <!-- Input -->
    <div style="margin-bottom:1.5rem;">
      <label for="w-date" id="w-label" style="display:block;font-size:.85rem;font-weight:600;margin-bottom:.4rem;color:var(--color-ink);">
        First day of last period
      </label>
      <input
        type="date"
        id="w-date"
        autocomplete="off"
        style="
          width:100%;max-width:320px;padding:.65rem .9rem;border-radius:var(--radius-sm);
          border:1.5px solid var(--color-line);background:var(--color-surface-2);
          font-size:1rem;color:var(--color-ink);font-family:var(--font-family-body);
        "
      />
    </div>

    <!-- Result panel -->
    <div id="w-result" aria-live="polite" style="min-height:270px;border-radius:var(--radius-sm);border:1.5px solid var(--color-line);overflow:hidden;">
      <div id="w-empty" style="height:270px;display:grid;place-items:center;text-align:center;padding:2rem;">
        <div>
          <svg width="38" height="46" viewBox="0 0 32 38" fill="none" aria-hidden="true" style="display:block;margin:0 auto .6rem;">
            <g fill="none" stroke="var(--color-primary)" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 36 C15.4 28 15.4 20 17.4 7"/>
              <path d="M15.6 27 C20 27 24 25 26.6 20.6 C22 20 18 22 15.6 27 Z"/>
              <path d="M16 22.5 C11.6 22.5 7.6 20.6 5 16.4 C9.6 15.8 13.8 17.8 16 22.5 Z"/>
              <path d="M16.5 17 C20.4 16.4 23.8 14.4 25.8 10.6 C21.6 10 18.2 12 16.5 17 Z"/>
              <path d="M16.8 12 C13.2 11.4 10 9.4 8 6.2 C11.6 5.8 15 7.8 16.8 12 Z"/>
            </g>
            <circle cx="17.6" cy="6.4" r="2.5" fill="var(--color-accent)"/>
          </svg>
          <p style="color:var(--color-muted);font-size:.95rem;margin:0;">Enter a date above to see your pregnancy week</p>
        </div>
      </div>

      <div id="w-content" style="display:none;padding:1.75rem;">
        <!-- Primary result -->
        <p id="w-trimester" style="font-size:.8rem;font-weight:600;text-transform:uppercase;letter-spacing:.07em;color:var(--color-primary);margin:0 0 .2rem;"></p>
        <p style="font-family:var(--font-family-display);font-size:clamp(1.8rem,5vw,2.6rem);font-weight:700;color:var(--color-accent);margin:0 0 .35rem;" id="w-weeks"></p>
        <p id="w-edd" style="font-size:.88rem;color:var(--color-muted);margin:0 0 1.25rem;"></p>

        <!-- Progress bar -->
        <div style="margin-bottom:1.5rem;">
          <div style="display:flex;justify-content:space-between;font-size:.78rem;color:var(--color-muted);margin-bottom:.35rem;">
            <span>Week 1</span><span id="w-pct"></span><span>Week 40</span>
          </div>
          <div style="height:8px;border-radius:4px;background:var(--color-surface-2);overflow:hidden;position:relative;">
            <div id="w-bar" style="height:100%;background:linear-gradient(90deg,var(--color-primary),var(--color-accent));border-radius:4px;transition:width .4s ease;width:0%;"></div>
          </div>
        </div>

        <!-- Next milestone -->
        <div id="w-milestone" style="padding:.8rem 1rem;background:transparent;border:1px solid var(--color-line);border-radius:3px;margin-bottom:1rem;"></div>

        <!-- Trimester blurb -->
        <p id="w-blurb" style="font-size:.87rem;color:var(--color-muted);margin:0;line-height:1.65;"></p>
      </div>
    </div>
  </div>

  <Fragment slot="content" set:html={copy.contentHtml} />
</ToolPage>

<!-- ── Client-side calculator ─────────────────────────────────── -->
<script>
  import { calculateWeeksPregnant, formatDate } from '../../islands/weeks-pregnant.ts';

  let mode: 'lmp' | 'edd' = 'lmp';

  const tabs = document.querySelectorAll<HTMLButtonElement>('[data-wmode]');
  const dateInput = document.getElementById('w-date') as HTMLInputElement;
  const wLabel    = document.getElementById('w-label') as HTMLLabelElement;
  const wEmpty   = document.getElementById('w-empty')!;
  const wContent = document.getElementById('w-content')!;

  // Restore URL state
  const params = new URLSearchParams(location.search);
  if (params.get('mode') === 'edd') applyMode('edd', false);
  if (params.get('date')) { dateInput.value = params.get('date')!; update(); }

  tabs.forEach(btn => {
    btn.addEventListener('click', () => {
      applyMode(btn.dataset.wmode as 'lmp' | 'edd', true);
      update();
    });
  });
  dateInput.addEventListener('input', update);

  function applyMode(m: 'lmp' | 'edd', reset: boolean) {
    mode = m;
    wLabel.textContent = m === 'lmp' ? 'First day of last period' : 'Your estimated due date (EDD)';
    tabs.forEach(btn => {
      const active = btn.dataset.wmode === m;
      btn.style.background = active ? 'var(--color-primary)' : 'transparent';
      btn.style.color = active ? '#fff' : 'var(--color-muted)';
      btn.style.borderColor = active ? 'var(--color-primary)' : 'var(--color-line)';
      btn.setAttribute('aria-selected', active ? 'true' : 'false');
    });
    if (reset) dateInput.value = '';
  }

  function update() {
    const date = dateInput.value;
    if (!date) { showEmpty(); return; }

    const r = calculateWeeksPregnant(mode === 'lmp' ? { lmp: date } : { edd: date });
    if (!r || r.trimester === 0) { showEmpty(); return; }

    // Persist URL
    const url = new URL(location.href);
    url.searchParams.set('mode', mode);
    url.searchParams.set('date', date);
    history.replaceState(null, '', url);

    // Render
    (document.getElementById('w-trimester') as HTMLElement).textContent = r.trimesterLabel;
    (document.getElementById('w-weeks') as HTMLElement).textContent = `${r.weeksComplete} weeks, ${r.daysRemainder} day${r.daysRemainder !== 1 ? 's' : ''}`;
    (document.getElementById('w-edd') as HTMLElement).textContent = `Due date: ${formatDate(r.edd)}`;
    (document.getElementById('w-pct') as HTMLElement).textContent = `${r.percentComplete}%`;
    (document.getElementById('w-bar') as HTMLElement).style.width = `${r.percentComplete}%`;

    // Milestone
    const ms = r.nextMilestone;
    const milestoneEl = document.getElementById('w-milestone')!;
    if (ms) {
      milestoneEl.innerHTML = `
        <p style="margin:0;font-size:.8rem;color:var(--color-muted);">Next milestone</p>
        <p style="margin:.2rem 0 0;font-size:.9rem;font-weight:600;color:var(--color-ink);">${ms.label} — ${ms.daysLeft} day${ms.daysLeft !== 1 ? 's' : ''} away (week ${ms.weeksGA})</p>
      `;
      milestoneEl.style.display = 'block';
    } else {
      milestoneEl.style.display = 'none';
    }

    (document.getElementById('w-blurb') as HTMLElement).textContent = r.trimesterBlurb;

    showResult();
  }

  function showEmpty() { wEmpty.style.display = 'grid'; wContent.style.display = 'none'; }
  function showResult() {
    wEmpty.style.display = 'none';
    wContent.style.display = 'block';
    wContent.classList.remove('result-animate');
    void wContent.offsetWidth;
    wContent.classList.add('result-animate');
  }
</script>
