---
import ToolPage from '../../layouts/ToolPage.astro';
import copy from '../../data/tools/due-date-calculator';
import { toolSchema } from '../../data/tools/_schema';
---

<ToolPage
  title={copy.title}
  headline={copy.headline}
  hook={copy.hook}
  description={copy.description}
  breadcrumbs={[{ label: copy.breadcrumb, href: copy.path }]}
  faqs={copy.faqs}
  relatedTools={copy.related}
  sources={copy.sources}
  schema={toolSchema(copy)}
  reviewedDate={copy.reviewedDate}
  embedSlug="due-date-calculator"
>

  <!-- ── TOOL SLOT ────────────────────────────────── -->
  <div slot="tool" id="due-date-calc">

    <!-- Method tabs -->
    <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1.5rem;" role="tablist" aria-label="Calculation method">
      {(['lmp','conception','ivf5','ivf3'] as const).map((m, i) => {
        const labels: Record<string, string> = { lmp: 'Last Period (LMP)', conception: 'Conception Date', ivf5: 'IVF Day-5', ivf3: 'IVF Day-3' };
        return (
          <button
            role="tab"
            data-method={m}
            aria-selected={i === 0 ? 'true' : 'false'}
            style={`
              padding: .45rem 1rem; border-radius: 999px; border: 1.5px solid;
              font-size: .82rem; font-weight: 600; cursor: pointer;
              transition: background .15s, color .15s, border-color .15s;
              ${i === 0
                ? 'background:var(--color-primary);color:#fff;border-color:var(--color-primary);'
                : 'background:transparent;color:var(--color-muted);border-color:var(--color-line);'}
            `}
          >
            {labels[m]}
          </button>
        );
      })}
    </div>

    <!-- Input row -->
    <div style="display:flex;gap:1rem;flex-wrap:wrap;align-items:flex-end;margin-bottom:1.5rem;">
      <div style="flex:1;min-width:200px;">
        <label for="calc-date" id="date-label" style="display:block;font-size:.85rem;font-weight:600;margin-bottom:.4rem;color:var(--color-ink);">
          First day of last period
        </label>
        <input
          type="date"
          id="calc-date"
          name="date"
          autocomplete="off"
          style="
            width:100%;padding:.65rem .9rem;border-radius:var(--radius-sm);
            border:1.5px solid var(--color-line);background:var(--color-surface-2);
            font-size:1rem;color:var(--color-ink);font-family:var(--font-family-body);
            transition:border-color .15s;outline:none;
          "
        />
      </div>

      <!-- Cycle length (shown only for LMP method) -->
      <div id="cycle-field" style="min-width:150px;">
        <label for="cycle-length" style="display:block;font-size:.85rem;font-weight:600;margin-bottom:.4rem;color:var(--color-ink);">
          Cycle length (days)
        </label>
        <div style="display:flex;align-items:center;gap:.5rem;">
          <button id="cycle-minus" aria-label="Decrease cycle length" style="width:44px;height:44px;border-radius:50%;border:1.5px solid var(--color-line);background:var(--color-surface-2);cursor:pointer;font-size:1.1rem;display:grid;place-items:center;">−</button>
          <input
            type="number"
            id="cycle-length"
            name="cycleLength"
            min="21" max="45" value="28"
            style="
              width:60px;text-align:center;padding:.5rem;border-radius:var(--radius-sm);
              border:1.5px solid var(--color-line);background:var(--color-surface-2);
              font-size:1rem;color:var(--color-ink);font-family:var(--font-family-mono);
            "
          />
          <button id="cycle-plus" aria-label="Increase cycle length" style="width:44px;height:44px;border-radius:50%;border:1.5px solid var(--color-line);background:var(--color-surface-2);cursor:pointer;font-size:1.1rem;display:grid;place-items:center;">+</button>
        </div>
      </div>
    </div>

    <!-- Result panel — pre-sized to prevent CLS -->
    <div
      id="result-panel"
      aria-live="polite"
      style="min-height:280px;border-radius:var(--radius-sm);border:1.5px solid var(--color-line);overflow:hidden;transition:border-color .2s;"
    >
      <!-- Empty state (shown before calculation) -->
      <div id="result-empty" style="height:280px;display:grid;place-items:center;text-align:center;padding:2rem;">
        <div>
          <svg width="38" height="46" viewBox="0 0 32 38" fill="none" aria-hidden="true" style="display:block;margin:0 auto .6rem;">
            <g fill="none" stroke="var(--color-primary)" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 36 C15.4 28 15.4 20 17.4 7"/>
              <path d="M15.6 27 C20 27 24 25 26.6 20.6 C22 20 18 22 15.6 27 Z"/>
              <path d="M16 22.5 C11.6 22.5 7.6 20.6 5 16.4 C9.6 15.8 13.8 17.8 16 22.5 Z"/>
              <path d="M16.5 17 C20.4 16.4 23.8 14.4 25.8 10.6 C21.6 10 18.2 12 16.5 17 Z"/>
              <path d="M16.8 12 C13.2 11.4 10 9.4 8 6.2 C11.6 5.8 15 7.8 16.8 12 Z"/>
            </g>
            <circle cx="17.6" cy="6.4" r="2.5" fill="var(--color-accent)"/>
          </svg>
          <p style="color:var(--color-muted);font-size:.95rem;margin:0;">Enter a date above to see your results</p>
        </div>
      </div>

      <!-- Populated state (hidden until calculated) -->
      <div id="result-content" style="display:none;padding:1.75rem;">
        <p id="res-example" hidden style="font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:var(--color-accent);border:1px solid currentColor;display:inline-block;padding:.25rem .6rem;margin:0 0 .85rem;">Example. Enter your date above</p>
        <p style="font-size:.8rem;font-weight:600;text-transform:uppercase;letter-spacing:.07em;color:var(--color-primary);margin:0 0 .35rem;" id="res-trimester"></p>
        <p style="margin:0 0 .2rem;color:var(--color-muted);font-size:.9rem;" id="res-gest-label"></p>
        <p style="font-family:var(--font-family-display);font-size:clamp(1.6rem,5vw,2.4rem);font-weight:700;color:var(--color-accent);margin:0 0 1.25rem;" id="res-edd"></p>

        <!-- Progress bar -->
        <div style="margin-bottom:1.5rem;">
          <div style="display:flex;justify-content:space-between;font-size:.78rem;color:var(--color-muted);margin-bottom:.35rem;">
            <span>Progress</span>
            <span id="res-pct"></span>
          </div>
          <div style="height:6px;border-radius:3px;background:var(--color-surface-2);overflow:hidden;">
            <div id="res-bar" style="height:100%;background:var(--color-primary);border-radius:3px;transition:width .4s ease;width:0%;"></div>
          </div>
        </div>

        <!-- Milestone list -->
        <div id="res-milestones" style="display:grid;gap:.5rem;margin-bottom:1.25rem;"></div>

        <!-- This week's note -->
        <div id="res-week-note" style="display:none;padding:.85rem 1rem;border:1px solid var(--color-line);border-left:3px solid var(--color-accent);margin-bottom:1.25rem;">
          <p id="res-week-note-title" style="margin:0 0 .25rem;font-size:.8rem;font-weight:600;text-transform:uppercase;letter-spacing:.07em;color:var(--color-accent);"></p>
          <p id="res-week-note-body" style="margin:0;font-size:.88rem;color:var(--color-ink);line-height:1.6;"></p>
        </div>

        <!-- Actions -->
        <div style="display:flex;gap:.5rem;flex-wrap:wrap;padding-top:1rem;border-top:1px solid var(--color-line);">
          <button onclick="navigator.clipboard?.writeText(document.getElementById('res-edd').textContent||'')" style="padding:.4rem .9rem;border-radius:999px;border:1.5px solid var(--color-line);background:transparent;cursor:pointer;font-size:.82rem;font-weight:500;color:var(--color-ink);">Copy date</button>
          <button onclick="window.print()" style="padding:.4rem .9rem;border-radius:999px;border:1.5px solid var(--color-line);background:transparent;cursor:pointer;font-size:.82rem;font-weight:500;color:var(--color-ink);">Print</button>
          <button id="ics-btn" style="padding:.4rem .9rem;border-radius:999px;border:1.5px solid var(--color-primary);background:transparent;cursor:pointer;font-size:.82rem;font-weight:500;color:var(--color-primary);">Add milestones to calendar</button>
        </div>
      </div>
    </div>
  </div>

  <Fragment slot="content" set:html={copy.contentHtml} />
</ToolPage>

<!-- ── Client-side calculator script ─────────────────────────── -->
<script>
  import type { DueDateInputs, DueDateMethod, DueDateResult } from '../../islands/due-date.ts';
  import { calculateDueDate, formatDate, formatDateShort } from '../../islands/due-date.ts';
  import { weekNote } from '../../data/week-notes.ts';
  import { downloadIcs } from '../../islands/ics.ts';

  const METHODS: DueDateMethod[] = ['lmp', 'conception', 'ivf5', 'ivf3'];
  const DATE_LABELS: Record<DueDateMethod, string> = {
    lmp: 'First day of last period',
    conception: 'Conception or ovulation date',
    ivf5: 'Day-5 embryo transfer date',
    ivf3: 'Day-3 embryo transfer date',
  };

  let activeMethod: DueDateMethod = 'lmp';
  let lastResult: DueDateResult | null = null;

  // DOM refs
  const tabs = document.querySelectorAll<HTMLButtonElement>('[data-method]');
  const dateInput = document.getElementById('calc-date') as HTMLInputElement;
  const dateLabel = document.getElementById('date-label') as HTMLLabelElement;
  const cycleField = document.getElementById('cycle-field') as HTMLElement;
  const cycleInput = document.getElementById('cycle-length') as HTMLInputElement;
  const cycleMinus = document.getElementById('cycle-minus') as HTMLButtonElement;
  const cyclePlus  = document.getElementById('cycle-plus')  as HTMLButtonElement;
  const resultEmpty   = document.getElementById('result-empty')!;
  const resultContent = document.getElementById('result-content')!;

  // URL state: restore on load
  const params = new URLSearchParams(location.search);
  if (params.get('method')) activeMethod = (params.get('method') as DueDateMethod) || 'lmp';
  if (params.get('date')) dateInput.value = params.get('date')!;
  if (params.get('cycle')) cycleInput.value = params.get('cycle')!;

  // No date yet? Show a worked example (10 weeks ago) so the payoff is visible immediately.
  let exampleMode = false;
  if (!dateInput.value) {
    const ex = new Date();
    ex.setDate(ex.getDate() - 70);
    dateInput.value = ex.toISOString().split('T')[0];
    exampleMode = true;
  }
  applyMethod(activeMethod, false);
  update();

  function userEdit() { exampleMode = false; update(); }

  // Tab clicks
  tabs.forEach(btn => {
    btn.addEventListener('click', () => {
      activeMethod = btn.dataset.method as DueDateMethod;
      exampleMode = false;
      applyMethod(activeMethod, true);
      update();
    });
  });

  // Inputs
  dateInput.addEventListener('input', userEdit);
  cycleInput.addEventListener('input', userEdit);
  cycleMinus.addEventListener('click', () => { cycleInput.value = String(Math.max(21, +cycleInput.value - 1)); userEdit(); });
  cyclePlus.addEventListener('click', () => { cycleInput.value = String(Math.min(45, +cycleInput.value + 1)); userEdit(); });

  // Calendar export: every milestone as an all-day event
  document.getElementById('ics-btn')!.addEventListener('click', () => {
    if (!lastResult) return;
    downloadIcs(
      lastResult.milestones.map((m) => ({
        title: `${m.label} (week ${m.weeksGA})`,
        date: m.date,
        description: 'From the Sage & Sprout due date calculator. Dates are estimates; confirm with your provider.',
      })),
      'pregnancy-milestones',
      'Pregnancy milestones',
    );
  });

  function applyMethod(m: DueDateMethod, resetDate: boolean) {
    tabs.forEach(btn => {
      const isActive = btn.dataset.method === m;
      btn.style.background = isActive ? 'var(--color-primary)' : 'transparent';
      btn.style.color = isActive ? '#fff' : 'var(--color-muted)';
      btn.style.borderColor = isActive ? 'var(--color-primary)' : 'var(--color-line)';
      btn.setAttribute('aria-selected', isActive ? 'true' : 'false');
    });
    dateLabel.textContent = DATE_LABELS[m];
    cycleField.style.display = m === 'lmp' ? 'block' : 'none';
    if (resetDate) dateInput.value = '';
  }

  function update() {
    const date = dateInput.value;
    if (!date) { showEmpty(); return; }

    const inputs: DueDateInputs = {
      method: activeMethod,
      date,
      cycleLength: activeMethod === 'lmp' ? Number(cycleInput.value) : undefined,
    };

    const r = calculateDueDate(inputs);
    if (!r) { showEmpty(); return; }
    lastResult = r;

    (document.getElementById('res-example') as HTMLElement).hidden = !exampleMode;

    // This week's note (skip when the date is preconception)
    const wn = !r.isPreconception ? weekNote(r.weeksComplete) : null;
    const noteBox = document.getElementById('res-week-note')!;
    if (wn) {
      (document.getElementById('res-week-note-title') as HTMLElement).textContent =
        `Week ${wn.week}: about the size of a ${wn.size}`;
      (document.getElementById('res-week-note-body') as HTMLElement).textContent =
        `${wn.note} Check back next week for what changes.`;
      noteBox.style.display = 'block';
    } else {
      noteBox.style.display = 'none';
    }

    // Persist URL state (no reload) — but never for the example values
    if (!exampleMode) {
      const url = new URL(location.href);
      url.searchParams.set('method', activeMethod);
      url.searchParams.set('date', date);
      if (activeMethod === 'lmp') url.searchParams.set('cycle', cycleInput.value);
      history.replaceState(null, '', url);
    }

    // Render
    (document.getElementById('res-trimester') as HTMLElement).textContent = r.trimesterLabel;
    (document.getElementById('res-gest-label') as HTMLElement).textContent = r.gestAgeLabel;
    (document.getElementById('res-edd') as HTMLElement).textContent = formatDate(r.edd);
    (document.getElementById('res-pct') as HTMLElement).textContent = `${r.percentComplete}% complete`;
    (document.getElementById('res-bar') as HTMLElement).style.width = `${r.percentComplete}%`;

    // Milestones
    const milestoneEl = document.getElementById('res-milestones')!;
    const upcoming = r.milestones.filter(m => m.date >= r.today);
    milestoneEl.innerHTML = upcoming.slice(0, 4).map(m => `
      <div style="display:flex;justify-content:space-between;align-items:center;font-size:.83rem;padding:.4rem 0;border-bottom:1px solid var(--color-line);">
        <span style="color:var(--color-muted);">${m.label}</span>
        <span style="font-family:var(--font-family-mono);font-weight:500;">${formatDateShort(m.date)}</span>
      </div>
    `).join('');

    showResult();
  }

  function showEmpty() {
    resultEmpty.style.display = 'grid';
    resultContent.style.display = 'none';
  }
  function showResult() {
    resultEmpty.style.display = 'none';
    resultContent.style.display = 'block';
    resultContent.classList.remove('result-animate');
    void resultContent.offsetWidth; // force reflow
    resultContent.classList.add('result-animate');
  }
</script>
