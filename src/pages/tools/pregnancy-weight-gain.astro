---
import ToolPage from '../../layouts/ToolPage.astro';
import copy from '../../data/tools/pregnancy-weight-gain';
import { toolSchema } from '../../data/tools/_schema';
---

<ToolPage
  title={copy.title}
  headline={copy.headline}
  hook={copy.hook}
  description={copy.description}
  breadcrumbs={[{ label: copy.breadcrumb, href: copy.path }]}
  faqs={copy.faqs}
  relatedTools={copy.related}
  sources={copy.sources}
  schema={toolSchema(copy)}
  reviewedDate={copy.reviewedDate}
>
  <div slot="tool">
    <!-- Inputs -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem 1.5rem;margin-bottom:1.5rem;" id="wg-form">

      <div>
        <label style="display:block;font-size:0.82rem;font-weight:600;color:var(--color-muted);margin-bottom:0.4rem;" for="wg-height-ft">Height (pre-pregnancy)</label>
        <div style="display:flex;gap:0.5rem;">
          <div style="display:flex;align-items:center;gap:0.25rem;flex:1;">
            <input id="wg-height-ft" type="number" min="3" max="8" value="5"
              style="width:100%;padding:0.7rem 0.9rem;border:1.5px solid var(--color-line);border-radius:var(--radius-sm);font-size:1rem;color:var(--color-ink);background:var(--color-bg);" />
            <span style="font-size:0.85rem;color:var(--color-muted);white-space:nowrap;">ft</span>
          </div>
          <div style="display:flex;align-items:center;gap:0.25rem;flex:1;">
            <input id="wg-height-in" type="number" min="0" max="11" value="5"
              style="width:100%;padding:0.7rem 0.9rem;border:1.5px solid var(--color-line);border-radius:var(--radius-sm);font-size:1rem;color:var(--color-ink);background:var(--color-bg);" />
            <span style="font-size:0.85rem;color:var(--color-muted);">in</span>
          </div>
        </div>
      </div>

      <div>
        <label style="display:block;font-size:0.82rem;font-weight:600;color:var(--color-muted);margin-bottom:0.4rem;" for="wg-weight">Pre-pregnancy weight (lb)</label>
        <input id="wg-weight" type="number" min="80" max="450" value="140"
          style="width:100%;padding:0.7rem 0.9rem;border:1.5px solid var(--color-line);border-radius:var(--radius-sm);font-size:1rem;color:var(--color-ink);background:var(--color-bg);box-sizing:border-box;" />
      </div>

      <div>
        <label style="display:block;font-size:0.82rem;font-weight:600;color:var(--color-muted);margin-bottom:0.4rem;" for="wg-weeks">Current gestational week</label>
        <input id="wg-weeks" type="number" min="1" max="42" value="20"
          style="width:100%;padding:0.7rem 0.9rem;border:1.5px solid var(--color-line);border-radius:var(--radius-sm);font-size:1rem;color:var(--color-ink);background:var(--color-bg);box-sizing:border-box;" />
      </div>

      <div>
        <label style="display:block;font-size:0.82rem;font-weight:600;color:var(--color-muted);margin-bottom:0.4rem;">Pregnancy type</label>
        <div style="display:flex;gap:0.75rem;padding-top:0.25rem;">
          <label style="display:flex;align-items:center;gap:0.4rem;cursor:pointer;font-size:0.95rem;">
            <input type="radio" name="wg-twins" value="false" checked id="wg-singleton" /> Singleton
          </label>
          <label style="display:flex;align-items:center;gap:0.4rem;cursor:pointer;font-size:0.95rem;">
            <input type="radio" name="wg-twins" value="true" id="wg-twins" /> Twins
          </label>
        </div>
      </div>
    </div>

    <button id="wg-calculate"
      class="btn btn--primary btn--block">
      Calculate weight gain range
    </button>

    <!-- Result panel (pre-sized to prevent CLS) -->
    <div id="wg-result" style="min-height:260px;margin-top:1.5rem;display:none;">
      <div id="wg-bmi-row" style="display:flex;align-items:center;gap:1rem;margin-bottom:1.25rem;padding:0.85rem 1rem;background:transparent;border:1px solid var(--color-line);border-radius:3px;">
        <div>
          <p style="margin:0;font-size:0.78rem;color:var(--color-muted);font-weight:600;">PRE-PREGNANCY BMI</p>
          <p id="wg-bmi" style="margin:0.15rem 0 0;font-size:1.6rem;font-family:var(--font-family-display);font-weight:700;color:var(--color-primary);"></p>
        </div>
        <div style="height:40px;width:1px;background:var(--color-line);"></div>
        <div>
          <p style="margin:0;font-size:0.78rem;color:var(--color-muted);font-weight:600;">BMI CATEGORY</p>
          <p id="wg-bmi-cat" style="margin:0.15rem 0 0;font-size:0.95rem;color:var(--color-ink);font-weight:600;"></p>
        </div>
      </div>

      <div style="text-align:center;margin-bottom:1.5rem;">
        <p style="margin:0;font-size:0.82rem;font-weight:600;color:var(--color-muted);">TOTAL RECOMMENDED GAIN</p>
        <p id="wg-total" style="margin:0.25rem 0 0;font-size:2.4rem;font-family:var(--font-family-display);font-weight:700;color:var(--color-accent);"></p>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">
        <div style="padding:0.9rem;background:transparent;border:1px solid var(--color-line);border-radius:3px;text-align:center;">
          <p style="margin:0;font-size:0.78rem;color:var(--color-muted);font-weight:600;">EXPECTED BY WEEK <span id="wg-week-label"></span></p>
          <p id="wg-target" style="margin:0.2rem 0 0;font-size:1.2rem;font-weight:700;color:var(--color-ink);"></p>
        </div>
        <div style="padding:0.9rem;background:transparent;border:1px solid var(--color-line);border-radius:3px;text-align:center;">
          <p style="margin:0;font-size:0.78rem;color:var(--color-muted);font-weight:600;">REMAINING</p>
          <p id="wg-remaining" style="margin:0.2rem 0 0;font-size:1.2rem;font-weight:700;color:var(--color-ink);"></p>
        </div>
      </div>

      <p id="wg-weekly" style="margin:0;font-size:0.85rem;color:var(--color-muted);text-align:center;"></p>
    </div>
  </div>

  <Fragment slot="content" set:html={copy.contentHtml} />
</ToolPage>

<script>
  import { calculateWeightGain } from '../../islands/weight-gain.js';

  function calc() {
    const ft   = parseFloat((document.getElementById('wg-height-ft') as HTMLInputElement).value) || 0;
    const inch = parseFloat((document.getElementById('wg-height-in') as HTMLInputElement).value) || 0;
    const wt   = parseFloat((document.getElementById('wg-weight') as HTMLInputElement).value) || 0;
    const wks  = parseFloat((document.getElementById('wg-weeks') as HTMLInputElement).value) || 0;
    const twins = (document.querySelector('input[name="wg-twins"]:checked') as HTMLInputElement)?.value === 'true';

    const result = calculateWeightGain({ heightFt: ft, heightIn: inch, weightLbs: wt, twins, gestWeeks: wks });
    if (!result) return;

    const panel = document.getElementById('wg-result')!;
    panel.style.display = 'block';

    document.getElementById('wg-bmi')!.textContent = result.bmi.toString();
    document.getElementById('wg-bmi-cat')!.textContent = result.bmiCategory;
    document.getElementById('wg-total')!.textContent = `${result.totalRangeLow}–${result.totalRangeHigh} lb`;
    document.getElementById('wg-week-label')!.textContent = wks.toString();
    document.getElementById('wg-target')!.textContent = `${result.targetAtCurrentWeek}–${result.targetAtCurrentWeekHigh} lb`;
    document.getElementById('wg-remaining')!.textContent =
      result.remainingHigh > 0 ? `${result.remainingLow}–${result.remainingHigh} lb` : 'On track';
    document.getElementById('wg-weekly')!.textContent =
      `T2/T3 rate: ~${result.weeklyRateLow}–${result.weeklyRateHigh} lb/week`;

    // Persist URL state
    const url = new URL(window.location.href);
    url.searchParams.set('ft', ft.toString());
    url.searchParams.set('in', inch.toString());
    url.searchParams.set('wt', wt.toString());
    url.searchParams.set('wks', wks.toString());
    if (twins) url.searchParams.set('twins', '1');
    history.replaceState(null, '', url);
  }

  document.getElementById('wg-calculate')!.addEventListener('click', calc);

  // Restore from URL
  const p = new URLSearchParams(window.location.search);
  if (p.get('ft')) (document.getElementById('wg-height-ft') as HTMLInputElement).value = p.get('ft')!;
  if (p.get('in')) (document.getElementById('wg-height-in') as HTMLInputElement).value = p.get('in')!;
  if (p.get('wt')) (document.getElementById('wg-weight') as HTMLInputElement).value = p.get('wt')!;
  if (p.get('wks')) (document.getElementById('wg-weeks') as HTMLInputElement).value = p.get('wks')!;
  if (p.get('twins') === '1') (document.getElementById('wg-twins') as HTMLInputElement).checked = true;
  if (p.get('wt') && p.get('wks')) calc();
</script>
