---
import ToolPage from '../../layouts/ToolPage.astro';
import copy from '../../data/tools/diaper-cost-calculator';
import { toolSchema } from '../../data/tools/_schema';
---

<ToolPage
  title={copy.title}
  headline={copy.headline}
  hook={copy.hook}
  description={copy.description}
  breadcrumbs={[{ label: copy.breadcrumb, href: copy.path }]}
  faqs={copy.faqs}
  relatedTools={copy.related}
  sources={copy.sources}
  schema={toolSchema(copy)}
  reviewedDate={copy.reviewedDate}
>
  <div slot="tool">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;margin-bottom:1.25rem;">
      <div>
        <label style="display:block;font-size:0.82rem;font-weight:600;color:var(--color-muted);margin-bottom:0.4rem;" for="dc-age">Baby's age (months)</label>
        <input id="dc-age" type="number" min="0" max="36" value="3" />
      </div>
      <div>
        <label style="display:block;font-size:0.82rem;font-weight:600;color:var(--color-muted);margin-bottom:0.4rem;" for="dc-diaper-price">Price per diaper ($)</label>
        <input id="dc-diaper-price" type="number" min="0.10" max="1.00" step="0.01" value="0.25" />
      </div>
      <div>
        <label style="display:block;font-size:0.82rem;font-weight:600;color:var(--color-muted);margin-bottom:0.4rem;" for="dc-wipe-price">Price per wipe ($)</label>
        <input id="dc-wipe-price" type="number" min="0.01" max="0.30" step="0.01" value="0.03" />
      </div>
      <div>
        <label style="display:block;font-size:0.82rem;font-weight:600;color:var(--color-muted);margin-bottom:0.4rem;" for="dc-wipes-per">Wipes per change</label>
        <input id="dc-wipes-per" type="number" min="1" max="8" value="2" />
      </div>
    </div>


    <!-- Result panel -->
    <div id="dc-result" style="min-height:240px;margin-top:1.5rem;display:none;">

      <!-- Size/stage banner -->
      <div style="padding:0.85rem 1rem;background:transparent;border:1px solid var(--color-line);border-radius:3px;margin-bottom:1.25rem;display:flex;justify-content:space-between;align-items:center;">
        <div>
          <p style="margin:0;font-size:0.75rem;color:var(--color-muted);font-weight:600;">STAGE</p>
          <p id="dc-stage" style="margin:0.1rem 0 0;font-size:0.95rem;font-weight:700;color:var(--color-ink);"></p>
        </div>
        <div style="text-align:right;">
          <p style="margin:0;font-size:0.75rem;color:var(--color-muted);font-weight:600;">DIAPER SIZE</p>
          <p id="dc-size" style="margin:0.1rem 0 0;font-size:0.95rem;font-weight:700;color:var(--color-primary);"></p>
        </div>
      </div>

      <!-- Usage grid -->
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:0.75rem;margin-bottom:1.25rem;">
        <div style="padding:0.85rem 0.5rem;background:transparent;border:1px solid var(--color-line);border-radius:3px;text-align:center;">
          <p style="margin:0;font-size:0.7rem;color:var(--color-muted);font-weight:600;">DIAPERS/DAY</p>
          <p id="dc-dpd" style="margin:0.15rem 0 0;font-size:1.5rem;font-weight:700;color:var(--color-ink);"></p>
        </div>
        <div style="padding:0.85rem 0.5rem;background:transparent;border:1px solid var(--color-line);border-radius:3px;text-align:center;">
          <p style="margin:0;font-size:0.7rem;color:var(--color-muted);font-weight:600;">DIAPERS/MONTH</p>
          <p id="dc-dpm" style="margin:0.15rem 0 0;font-size:1.5rem;font-weight:700;color:var(--color-ink);"></p>
        </div>
        <div style="padding:0.85rem 0.5rem;background:transparent;border:1px solid var(--color-line);border-radius:3px;text-align:center;">
          <p style="margin:0;font-size:0.7rem;color:var(--color-muted);font-weight:600;">WIPES/MONTH</p>
          <p id="dc-wpm" style="margin:0.15rem 0 0;font-size:1.5rem;font-weight:700;color:var(--color-ink);"></p>
        </div>
      </div>

      <!-- Cost summary -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">
        <div style="padding:1.1rem;background:transparent;border:1px solid var(--color-line);border-radius:3px;text-align:center;">
          <p style="margin:0;font-size:0.75rem;color:var(--color-muted);font-weight:600;">MONTHLY TOTAL</p>
          <p id="dc-monthly" style="margin:0.2rem 0 0;font-size:2rem;font-family:var(--font-family-display);font-weight:700;color:var(--color-accent);"></p>
          <p id="dc-monthly-break" style="margin:0.2rem 0 0;font-size:0.75rem;color:var(--color-muted);"></p>
        </div>
        <div style="padding:1.1rem;background:var(--color-primary);border-radius:var(--radius-sm);text-align:center;">
          <p style="margin:0;font-size:0.75rem;color:rgba(255,255,255,.8);font-weight:600;">YEARLY TOTAL</p>
          <p id="dc-yearly" style="margin:0.2rem 0 0;font-size:2rem;font-family:var(--font-family-display);font-weight:700;color:#fff;"></p>
        </div>
      </div>
    </div>
  </div>

  <Fragment slot="content" set:html={copy.contentHtml} />
</ToolPage>

<script>
  import { calculateDiaperCost } from '../../islands/diaper-cost.js';

  function calc() {
    const age        = parseFloat((document.getElementById('dc-age') as HTMLInputElement).value) || 0;
    const diaperP    = parseFloat((document.getElementById('dc-diaper-price') as HTMLInputElement).value) || 0;
    const wipeP      = parseFloat((document.getElementById('dc-wipe-price') as HTMLInputElement).value) || 0;
    const wipesPerC  = parseFloat((document.getElementById('dc-wipes-per') as HTMLInputElement).value) || 2;

    const result = calculateDiaperCost({ babyAgeMonths: age, diaperPricePerUnit: diaperP, wipesPerDiaper: wipesPerC, wipesPricePerUnit: wipeP });
    if (!result) return;

    const panel = document.getElementById('dc-result')!;
    panel.style.display = 'block';

    document.getElementById('dc-stage')!.textContent = result.stageLabel;
    document.getElementById('dc-size')!.textContent  = result.diaperSize;
    document.getElementById('dc-dpd')!.textContent   = result.diapersPerDay.toString();
    document.getElementById('dc-dpm')!.textContent   = result.diapersPerMonth.toString();
    document.getElementById('dc-wpm')!.textContent   = result.wipesPerMonth.toString();

    const monthly = '$' + result.monthlyCost.toFixed(2);
    document.getElementById('dc-monthly')!.textContent = monthly;
    document.getElementById('dc-monthly-break')!.textContent =
      `Diapers $${result.diaperMonthlyCost.toFixed(2)} + Wipes $${result.wipesMonthlyCost.toFixed(2)}`;
    document.getElementById('dc-yearly')!.textContent = '$' + result.yearlyCost.toFixed(2);

    const url = new URL(window.location.href);
    url.searchParams.set('age', age.toString());
    url.searchParams.set('dp', diaperP.toString());
    url.searchParams.set('wp', wipeP.toString());
    history.replaceState(null, '', url);
  }

  // Restore from URL
  const p = new URLSearchParams(window.location.search);
  if (p.get('age')) (document.getElementById('dc-age') as HTMLInputElement).value = p.get('age')!;
  if (p.get('dp'))  (document.getElementById('dc-diaper-price') as HTMLInputElement).value = p.get('dp')!;
  if (p.get('wp'))  (document.getElementById('dc-wipe-price') as HTMLInputElement).value = p.get('wp')!;

  // Live-update
  let _t: ReturnType<typeof setTimeout>;
  ['dc-age', 'dc-diaper-price', 'dc-wipe-price', 'dc-wipes-per'].forEach(id =>
    document.getElementById(id)!.addEventListener('input', () => { clearTimeout(_t); _t = setTimeout(calc, 150); })
  );

  calc();
</script>
