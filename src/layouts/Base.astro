---
import '../styles/global.css';
import { site } from '../data/site';
import { baseGraph } from '../data/entities';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  schema?: object | object[];
  breadcrumbs?: { label: string; href: string }[];
}

const {
  title,
  description,
  canonical,
  ogImage = '/og-default.png',
  noindex = false,
  schema,
  breadcrumbs,
} = Astro.props;

const canonicalURL = canonical
  ? new URL(canonical, Astro.site)
  : new URL(Astro.url.pathname, Astro.site);

const schemaArray = schema
  ? (Array.isArray(schema) ? schema : [schema])
  : [];

const navLinks = site.nav;
const footerTools = site.tools;

const toolStages = [
  { key: 'conceive', label: 'Trying to conceive' },
  { key: 'pregnancy', label: 'Pregnancy' },
  { key: 'baby', label: "Baby's first years" },
] as const;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  {noindex && <meta name="robots" content="noindex,nofollow" />}

  <!-- OG -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={new URL(ogImage, Astro.site)} />
  <meta property="og:site_name" content="Sage & Sprout" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="theme-color" content="#3E5A49" />

  <!-- Fonts: preconnect + stylesheet -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=JetBrains+Mono:wght@400;500&display=swap"
  />

  <!-- Favicon + PWA -->
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="manifest" href="/manifest.webmanifest" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  <!-- Google AdSense -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4713095371071566" crossorigin="anonymous"></script>

  <!-- JSON-LD: Organization + WebSite (sitewide) + page-specific schema -->
  <script type="application/ld+json" set:html={JSON.stringify(baseGraph())} />
  {schemaArray.map((s) => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}
</head>

<body>
  <!-- ── Header ──────────────────────────────────────── -->
  <header style="background: transparent;">
    <div style="max-width: var(--maxw); margin: 0 auto; padding: 1.4rem 1.5rem; display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap;">
      <a href="/" style="text-decoration: none; display: flex; align-items: center; gap: 0.6rem;" aria-label="Sage & Sprout home">
        <svg width="27" height="32" viewBox="0 0 32 38" aria-hidden="true">
          <g class="sprig" stroke="var(--color-primary)" stroke-width="1.6">
            <path d="M16 36 C15.4 28 15.4 20 17.4 7" />
            <path d="M15.6 27 C20 27 24 25 26.6 20.6 C22 20 18 22 15.6 27 Z" />
            <path d="M16 22.5 C11.6 22.5 7.6 20.6 5 16.4 C9.6 15.8 13.8 17.8 16 22.5 Z" />
            <path d="M16.5 17 C20.4 16.4 23.8 14.4 25.8 10.6 C21.6 10 18.2 12 16.5 17 Z" />
            <path d="M16.8 12 C13.2 11.4 10 9.4 8 6.2 C11.6 5.8 15 7.8 16.8 12 Z" />
          </g>
          <circle cx="17.6" cy="6.4" r="2.5" fill="var(--color-accent)" />
        </svg>
        <span style="font-family: var(--font-family-display); font-weight: 500; font-size: 1.2rem; color: var(--color-ink); letter-spacing: -0.01em;">
          Sage <span style="font-style: italic; font-weight: 400;">&amp;</span> Sprout
        </span>
      </a>
      <nav aria-label="Main navigation">
        <ul style="list-style: none; margin: 0; padding: 0; display: flex; align-items: center; gap: 0.15rem; flex-wrap: wrap;">
          {navLinks.map(({ href, label }) => (
            <li><a href={href} class="pill">{label}</a></li>
          ))}
          <li>
            <details class="nav-menu" id="nav-tools-menu">
              <summary class="pill pill--accent" aria-label="All tools menu">{site.navCta.label}</summary>
              <div class="nav-menu-panel">
                {toolStages.map(({ key, label }) => (
                  <div>
                    <p class="eyebrow" style="margin:0 0 .6rem;">{label}</p>
                    <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:.45rem;">
                      {site.tools.filter((t) => t.stage === key).map((t) => (
                        <li><a href={t.href} class="nav-menu-link">{t.name}</a></li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            </details>
          </li>
        </ul>
      </nav>
    </div>
  </header>

  <!-- ── Breadcrumb ─────────────────────────────────── -->
  {breadcrumbs && breadcrumbs.length > 0 && (
    <div style="max-width: var(--maxw); margin: 0 auto; padding: 0.5rem 1.5rem 0;">
      <nav aria-label="Breadcrumb">
        <ol style="list-style:none;margin:0;padding:0;display:flex;align-items:center;gap:0.45rem;flex-wrap:wrap;font-size:0.8rem;color:var(--color-muted);">
          <li><a href="/" style="color:var(--color-muted);text-decoration:none;">Home</a></li>
          {breadcrumbs.map(({ href, label }, i) => (
            <>
              <li aria-hidden="true" style="opacity:.5">/</li>
              <li>
                {i === breadcrumbs.length - 1
                  ? <span style="color:var(--color-ink)">{label}</span>
                  : <a href={href} style="color:var(--color-muted);text-decoration:none;">{label}</a>}
              </li>
            </>
          ))}
        </ol>
      </nav>
    </div>
  )}

  <!-- ── Page content ───────────────────────────────── -->
  <main>
    <slot />
  </main>

  <!-- ── Footer ─────────────────────────────────────── -->
  <footer style="margin-top: 5rem; background: var(--color-surface);">
    <hr class="rule" />
    <div style="max-width: var(--maxw); margin: 0 auto; padding: 3rem 1.5rem 2.5rem;">
      <div style="display: grid; gap: 2.5rem; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));">
        <div>
          <div style="display:flex;align-items:center;gap:0.5rem;margin:0 0 0.7rem;">
            <svg width="20" height="24" viewBox="0 0 32 38" aria-hidden="true">
              <g class="sprig" stroke="var(--color-primary)" stroke-width="1.8">
                <path d="M16 36 C15.4 28 15.4 20 17.4 7" />
                <path d="M15.6 27 C20 27 24 25 26.6 20.6 C22 20 18 22 15.6 27 Z" />
                <path d="M16 22.5 C11.6 22.5 7.6 20.6 5 16.4 C9.6 15.8 13.8 17.8 16 22.5 Z" />
                <path d="M16.5 17 C20.4 16.4 23.8 14.4 25.8 10.6 C21.6 10 18.2 12 16.5 17 Z" />
                <path d="M16.8 12 C13.2 11.4 10 9.4 8 6.2 C11.6 5.8 15 7.8 16.8 12 Z" />
              </g>
              <circle cx="17.6" cy="6.4" r="2.6" fill="var(--color-accent)" />
            </svg>
            <p style="font-family:var(--font-family-display);font-size:1.15rem;font-weight:500;margin:0;">Sage <span style="font-style:italic;font-weight:400;">&amp;</span> Sprout</p>
          </div>
          <p style="font-size:0.85rem;color:var(--color-muted);margin:0;max-width:30ch;line-height:1.6;">{site.footer.blurb}</p>
        </div>
        <div>
          <p class="eyebrow" style="margin:0 0 0.9rem;">All tools</p>
          <ul style="list-style:none;margin:0;padding:0;display:grid;grid-template-columns:1fr 1fr;gap:0.5rem 1.25rem;">
            {footerTools.map(({ href, name }) => (
              <li><a href={href} style="font-size:0.85rem;color:var(--color-ink);text-decoration:none;opacity:.85;">{name}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <p class="eyebrow" style="margin:0 0 0.9rem;">{site.footer.moreLabel}</p>
          <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:0.5rem;">
            {site.footer.moreLinks.map(({ href, label }) => (
              <li><a href={href} style="font-size:0.88rem;color:var(--color-ink);text-decoration:none;opacity:.85;">{label}</a></li>
            ))}
          </ul>
        </div>
      </div>
      <hr class="rule" style="margin:2.5rem 0 1.5rem;" />
      <div style="font-size:0.76rem;color:var(--color-muted);line-height:1.6;">
        <p style="margin:0 0 0.4rem;"><strong style="color:var(--color-ink);font-weight:600;">Medical disclaimer:</strong> <Fragment set:html={site.footer.disclaimer} /></p>
        <p style="margin:0;">© {new Date().getFullYear()} Sage &amp; Sprout · <a href="/privacy/" style="color:var(--color-muted);">Privacy</a> · <a href="/terms/" style="color:var(--color-muted);">Terms</a></p>
      </div>
    </div>
  </footer>

  <!-- Close the all-tools menu when clicking or tabbing away -->
  <script is:inline>
    document.addEventListener('click', (e) => {
      const menu = document.getElementById('nav-tools-menu');
      if (menu && menu.open && !menu.contains(e.target)) menu.open = false;
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        const menu = document.getElementById('nav-tools-menu');
        if (menu) menu.open = false;
      }
    });
  </script>

  <!-- Smooth scroll (Lenis) — buttery inertia, off for reduced-motion -->
  <script is:inline type="module">
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      try {
        const { default: Lenis } = await import('https://esm.sh/lenis@1.1.14');
        const lenis = new Lenis({ duration: 1.15, wheelMultiplier: 0.9, smoothWheel: true });
        function raf(time) { lenis.raf(time); requestAnimationFrame(raf); }
        requestAnimationFrame(raf);
        document.querySelectorAll('a[href^="#"]').forEach((a) => {
          a.addEventListener('click', (e) => {
            const id = a.getAttribute('href');
            if (id && id.length > 1) {
              const el = document.querySelector(id);
              if (el) { e.preventDefault(); lenis.scrollTo(el, { offset: -20 }); }
            }
          });
        });
      } catch (_) { /* smooth scroll is a progressive enhancement */ }
    }
  </script>
</body>
</html>
