---
/**
 * Standard template for every tool page.
 * Anatomy: breadcrumb → H1 → lead hook → [TOOL] → ad →
 * sprig divider → content → related → FAQ → sources → disclaimer
 */
import Base from './Base.astro';
import Icon from '../components/Icon.astro';
import { iconForHref } from '../data/tool-icons';

export interface FAQ {
  question: string;
  answer: string;
}

export interface RelatedTool {
  href: string;
  label: string;
  description: string;
  emoji?: string;
}

export interface Source {
  label: string;
  url: string;
}

export interface Props {
  title: string;
  headline: string;
  hook: string;
  description: string;
  breadcrumbs: { label: string; href: string }[];
  faqs: FAQ[];
  relatedTools: RelatedTool[];
  sources: Source[];
  schema: object | object[];
  reviewedDate?: string;
}

const {
  title,
  headline,
  hook,
  description,
  breadcrumbs,
  faqs,
  relatedTools,
  sources,
  schema,
  reviewedDate = new Date().toISOString().split('T')[0],
} = Astro.props;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: { '@type': 'Answer', text: answer },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://sage-and-sprout.com/' },
    ...breadcrumbs.map(({ label, href }, i) => ({
      '@type': 'ListItem',
      position: i + 2,
      name: label,
      item: `https://sage-and-sprout.com${href}`,
    })),
  ],
};

const allSchema = [
  ...(Array.isArray(schema) ? schema : [schema]),
  faqSchema,
  breadcrumbSchema,
];
---

<Base
  title={title}
  description={description}
  breadcrumbs={breadcrumbs}
  schema={allSchema}
>
  <div class="tool-wrapper" style="max-width: 760px; margin: 0 auto;">

    <!-- H1 + lead hook -->
    <div style="display:flex;align-items:flex-start;gap:0.85rem;margin-bottom:1rem;">
      <svg width="26" height="32" viewBox="0 0 32 38" fill="none" aria-hidden="true" style="flex-shrink:0;margin-top:0.4rem;">
        <g class="sprig" stroke="var(--color-primary)" stroke-width="1.7">
          <path d="M16 36 C15.4 28 15.4 20 17.4 7" />
          <path d="M15.6 27 C20 27 24 25 26.6 20.6 C22 20 18 22 15.6 27 Z" />
          <path d="M16 22.5 C11.6 22.5 7.6 20.6 5 16.4 C9.6 15.8 13.8 17.8 16 22.5 Z" />
          <path d="M16.5 17 C20.4 16.4 23.8 14.4 25.8 10.6 C21.6 10 18.2 12 16.5 17 Z" />
          <path d="M16.8 12 C13.2 11.4 10 9.4 8 6.2 C11.6 5.8 15 7.8 16.8 12 Z" />
        </g>
        <circle cx="17.6" cy="6.4" r="2.5" fill="var(--color-accent)" />
      </svg>
      <h1 style="font-family:var(--font-family-display);font-size:clamp(1.9rem,4.5vw,2.8rem);font-weight:400;color:var(--color-ink);margin:0;letter-spacing:-0.015em;line-height:1.1;">{headline}</h1>
    </div>
    <p class="lead" style="font-size:1.2rem;color:var(--color-ink);max-width:60ch;margin:0 0 2.25rem;line-height:1.6;opacity:.85;">{hook}</p>

    <!-- ── THE TOOL (above fold) ─────────────────── -->
    <div class="card tool-card">
      <slot name="tool" />
    </div>

    <!-- ── Share row (same affordance on every tool) ── -->
    <div style="display:flex;justify-content:flex-end;align-items:center;gap:.75rem;margin:0.75rem 0 1rem;">
      <span style="font-size:.78rem;color:var(--color-muted);">Link carries your inputs</span>
      <button id="tool-share" type="button" class="share-btn">Share result</button>
    </div>

    <!-- ── CLS-safe ad slot (below result) ───────── -->
    <div class="ad-slot ad-slot--banner" style="margin-bottom:1rem;" aria-hidden="true">
      Advertisement
    </div>

    <!-- ── Illustrated divider ─────────────────────── -->
    <div class="sprig-divider" aria-hidden="true">
      <svg width="32" height="20" viewBox="0 0 32 20" fill="none">
        <g class="sprig" stroke="currentColor" stroke-width="1.4">
          <path d="M3 10 H 24" />
          <path d="M12 10 C12 6.4 14 3.6 17.5 2.6 C17.5 6.2 15.5 9 12 10 Z" />
          <path d="M12 10 C12 13.6 14 16.4 17.5 17.4 C17.5 13.8 15.5 11 12 10 Z" />
          <path d="M19 10 C19 7.2 20.6 5 23.4 4.2 C23.4 7 21.8 9.4 19 10 Z" />
        </g>
        <circle cx="27" cy="10" r="2.4" fill="var(--color-accent)" />
      </svg>
    </div>

    <!-- ── Content below fold (cream sheet for readability) ── -->
    <article class="prose sheet tool-article">
      <slot name="content" />

      <!-- ── Related tools ─────────────────────── -->
      <h2>Keep exploring</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:1rem;margin-bottom:2rem;">
        {relatedTools.map(({ href, label, description: desc }) => (
          <a href={href} class="related-card">
            <Icon name={iconForHref(href)} size={26} />
            <span class="related-name">{label}<span class="related-arrow" aria-hidden="true"> →</span></span>
            <span style="font-size:0.82rem;color:var(--color-muted);line-height:1.45;">{desc}</span>
          </a>
        ))}
      </div>

      <!-- ── In-content ad slot ─────────────────── -->
      <div class="ad-slot" style="margin-bottom:2rem;" aria-hidden="true">Advertisement</div>

      <!-- ── FAQ ───────────────────────────────── -->
      <h2>Frequently asked questions</h2>
      <div style="display:flex;flex-direction:column;gap:0.75rem;margin-bottom:2rem;">
        {faqs.map(({ question, answer }) => (
          <details class="faq">
            <summary>
              {question}
              <span class="faq-icon" aria-hidden="true"></span>
            </summary>
            <div class="faq-body">{answer}</div>
          </details>
        ))}
      </div>

      <!-- ── Sources ────────────────────────────── -->
      <h2>Sources &amp; further reading</h2>
      <ol style="display:flex;flex-direction:column;gap:0.5rem;padding-left:1.25rem;margin-bottom:2rem;">
        {sources.map(({ label, url }) => (
          <li style="font-size:0.85rem;color:var(--color-muted);line-height:1.5;">
            <a href={url} target="_blank" rel="noopener noreferrer">{label}</a>
          </li>
        ))}
      </ol>

      <!-- ── Reviewed + disclaimer ───────────────── -->
      <div class="callout" style="border-left-color:var(--color-primary);">
        <svg width="20" height="24" viewBox="0 0 32 38" fill="none" aria-hidden="true">
          <g class="sprig" stroke="var(--color-primary)" stroke-width="1.8">
            <path d="M16 36 C15.4 28 15.4 20 17.4 7" />
            <path d="M15.6 27 C20 27 24 25 26.6 20.6 C22 20 18 22 15.6 27 Z" />
            <path d="M16 22.5 C11.6 22.5 7.6 20.6 5 16.4 C9.6 15.8 13.8 17.8 16 22.5 Z" />
            <path d="M16.5 17 C20.4 16.4 23.8 14.4 25.8 10.6 C21.6 10 18.2 12 16.5 17 Z" />
          </g>
          <circle cx="17.6" cy="6.4" r="2.6" fill="var(--color-accent)" />
        </svg>
        <div>
          <p style="margin:0 0 0.4rem;color:var(--color-ink);">
            Reviewed <time datetime={reviewedDate}>{reviewedDate}</time> by a senior medical student at an Ivy League institution. Every figure cites primary medical literature.
          </p>
          <p style="margin:0;color:var(--color-muted);font-size:0.85rem;">
            <strong style="color:var(--color-ink);">This is general educational information, not medical advice.</strong> Always consult your doctor, midwife, or qualified clinician for personal guidance.
            <a href="/medical-disclaimer/">Read the full disclaimer →</a>
          </p>
        </div>
      </div>
    </article>
  </div>
</Base>

<script>
  // Share the current tool state: native share sheet on mobile, clipboard elsewhere.
  const shareBtn = document.getElementById('tool-share') as HTMLButtonElement | null;
  if (shareBtn) {
    shareBtn.addEventListener('click', async () => {
      const url = location.href;
      if (navigator.share) {
        try { await navigator.share({ title: document.title, url }); return; } catch { /* user closed the sheet */ }
      }
      try {
        await navigator.clipboard.writeText(url);
        const original = shareBtn.textContent;
        shareBtn.textContent = 'Link copied!';
        setTimeout(() => { shareBtn.textContent = original; }, 1800);
      } catch { /* clipboard unavailable */ }
    });
  }
</script>

<style>
  /* ── Page wrapper ──────────────────────────────────── */
  .tool-wrapper {
    padding: 1.5rem 1.5rem 4rem;
    overflow-x: hidden;
  }
  @media (max-width: 520px) {
    .tool-wrapper { padding: 1.25rem 1rem 3rem; }
  }

  /* ── Calculator card ───────────────────────────────── */
  .tool-card {
    padding: 2rem 1.75rem;
    margin-bottom: 1.5rem;
  }
  @media (max-width: 520px) {
    .tool-card { padding: 1.5rem 1rem; }
  }

  /* ── Cream content sheet ───────────────────────────── */
  .tool-article {
    padding: 2.5rem 2rem;
    max-width: 100%;
  }
  @media (max-width: 520px) {
    .tool-article { padding: 2rem 1.25rem; }
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1.2rem;
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    text-decoration: none;
    border: 1px solid var(--color-line);
    transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
  }
  .related-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow);
    border-color: var(--color-primary);
  }
  .related-name {
    font-family: var(--font-family-display);
    font-weight: 500;
    font-size: 1.02rem;
    color: var(--color-ink);
  }
  .related-arrow { color: var(--color-accent); opacity: 0; transition: opacity .18s; }
  .related-card:hover .related-arrow { opacity: 1; }

  .faq {
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    overflow: hidden;
  }
  .faq summary {
    padding: 1.1rem 1.3rem;
    font-weight: 600;
    font-size: 0.96rem;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    color: var(--color-ink);
  }
  .faq summary::-webkit-details-marker { display: none; }
  .faq-icon {
    position: relative;
    width: 14px; height: 14px;
    flex-shrink: 0;
  }
  .faq-icon::before, .faq-icon::after {
    content: "";
    position: absolute;
    background: var(--color-accent);
    transition: transform .2s ease;
  }
  .faq-icon::before { top: 6px; left: 0; width: 14px; height: 2px; }
  .faq-icon::after { left: 6px; top: 0; width: 2px; height: 14px; }
  .faq[open] .faq-icon::after { transform: rotate(90deg); opacity: 0; }
  .faq-body {
    padding: 0 1.3rem 1.15rem;
    color: var(--color-muted);
    font-size: 0.92rem;
    line-height: 1.7;
  }
</style>
